{
  "name": "music-store",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "msw:worker": "npx msw init public --save && node scripts/msw/patch-worker.mjs",
    "dev": "npm run msw:worker && vite",
    "build": "npm run msw:worker && vite build",
    "analyze": "npm run msw:worker && vite build --mode analyze",
    "build:ci": "run-s -c ci build",
    "preview": "vite preview",
    "lint:fix": "run-s -c \"eslint . --ext ts,tsx,js,jsx --report-unused-disable-directives --max-warnings 0 --fix\" \"prettier --write .\"",
    "ci:lint": "eslint . --ext ts,tsx,js,jsx --report-unused-disable-directives --max-warnings 0",
    "ci:format": "prettier --check .",
    "ci:steiger": "steiger ./src",
    "ci:typecheck": "tsc -b",
    "ci:test": "node -e \"console.log('Test stub: OK')\"",
    "ci": "run-s -c ci:lint ci:format ci:steiger ci:typecheck ci:test",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-router": "^1.163.2",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "msw": "^2.13.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "steiger": "^0.5.11",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10"
  },
  "overrides": {
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=11"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
